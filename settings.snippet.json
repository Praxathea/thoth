{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "clear",
        "hooks": [
          { "type": "command", "command": "$HOME/.claude/hooks/load-handoff.sh" }
        ]
      },
      {
        "matcher": "startup",
        "hooks": [
          { "type": "command", "command": "$HOME/.claude/hooks/load-handoff.sh" }
        ]
      }
    ]
  }
}
